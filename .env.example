# Copie este arquivo para .env e preencha com suas credenciais reais.
# IMPORTANTE: nunca commite o .env real (já está no .gitignore via 'env*')

# ============================================================
# LivePDV / Moombox
# ============================================================
LIVEPDV_BASE_URL=https://expositores.moombox.com.br
LIVEPDV_USERNAME=seu_usuario_aqui
LIVEPDV_PASSWORD=sua_senha_aqui

# ============================================================
# Efí (Gerencianet) — Pagamentos + PIX
# ============================================================
# Obter em: https://app.efipay.com.br -> API -> Minhas Aplicações
EFI_CLIENT_ID=Client_Id_xxxxxxxxxxxxxxxx
EFI_CLIENT_SECRET=Client_Secret_xxxxxxxxxxxxxxxx

# Certificado PIX (.pem combinado OU .p12 convertido)
# Converter .p12 -> .pem:
#   openssl pkcs12 -in efi.p12 -out efi.pem -nodes
EFI_PIX_CERT_PATH=./certs/efi-prod.pem
EFI_PIX_KEY_PATH=

# Ambiente
EFI_SANDBOX=false

# Critério de inadimplência (dias após vencimento)
EFI_DIAS_ATRASO_MIN=1
